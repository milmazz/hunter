{
  "domain": "mastodon.example",
  "title": "Mastodon Example",
  "version": "4.3.8",
  "source_url": "https://github.com/mastodon/mastodon",
  "description": "A test instance",
  "usage": {
    "users": { "active_month": 2 }
  },
  "thumbnail": {
    "url": "https://mastodon.example/thumbnail.png"
  },
  "languages": ["en"],
